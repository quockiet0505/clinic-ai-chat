# Server
PORT=8000
HOST=0.0.0.0

# Ollama / LLM
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=llama3.2:3b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500

# Clinic Backend (Spring Boot)
CLINIC_BACKEND_URL=http://localhost:8080

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Light RAG (FAQ markdown in knowledge/)
RAG_ENABLED=true
RAG_TOP_K=3
RAG_MIN_SCORE=0.15
